#!/bin/sh
HERE="$(dirname "$(readlink -f "$0")")"
export PATH="$HERE/usr/bin:$PATH"
export LD_LIBRARY_PATH="$HERE/usr/lib:$HERE/usr/lib64:$LD_LIBRARY_PATH"

# Prompt for sudo password
if command -v zenity >/dev/null 2>&1; then
    SUDO_PASS=$(zenity --password --title="RazerControl Daemon" --text="Enter sudo password to start hardware daemon:" 2>/dev/null)
    RESULT=$?
    if [ $RESULT -ne 0 ]; then
        zenity --error --title="RazerControl" --text="Password entry cancelled or failed" 2>/dev/null || echo "Password entry cancelled"
        exit 1
    fi
else
    # Fallback: terminal prompt
    echo ""
    echo "RazerControl requires root access for hardware control"
    read -p "Enter sudo password: " -s SUDO_PASS
    echo ""
fi

# Copy daemon binary out of FUSE mount so root can execute it
# (FUSE mounts are not accessible by root unless user_allow_other is enabled)
DAEMON_TMP="/tmp/razer-daemon-appimage-bin"
cp "$HERE/usr/bin/razer-daemon" "$DAEMON_TMP"
chmod +x "$DAEMON_TMP"

# Copy laptops.json so daemon can find it
DATADIR_TMP="/tmp/razer-daemon-appimage-data"
mkdir -p "$DATADIR_TMP"
cp "$HERE/usr/share/razercontrol/laptops.json" "$DATADIR_TMP/" 2>/dev/null || true

# Start daemon with provided password, preserving environment
echo "$SUDO_PASS" | sudo -S -E env "PATH=$PATH" "LD_LIBRARY_PATH=$LD_LIBRARY_PATH" "RAZER_DEVICE_FILE=$DATADIR_TMP/laptops.json" "$DAEMON_TMP" >/tmp/razer-daemon-appimage.log 2>&1 &
DAEMON_PID=$!

# Give daemon time to initialize and check if it succeeded
sleep 2
if ! kill -0 "$DAEMON_PID" 2>/dev/null; then
    zenity --error --title="RazerControl Error" --text="Failed to start daemon. Check /tmp/razer-daemon-appimage.log for details." 2>/dev/null || cat /tmp/razer-daemon-appimage.log
    exit 1
fi

cleanup() {
    kill "$DAEMON_PID" 2>/dev/null || true
    echo "$SUDO_PASS" | sudo -S -k 2>/dev/null || true
    rm -f "$DAEMON_TMP"
    rm -rf "$DATADIR_TMP"
}
trap cleanup EXIT INT TERM

export RAZER_DEVICE_FILE="$DATADIR_TMP/laptops.json"
exec "$HERE/usr/bin/razer-settings" "$@"
